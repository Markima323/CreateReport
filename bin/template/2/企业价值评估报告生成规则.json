{
  "schema_version": "1.0",
  "document_type": "2",
  "name": "企业价值评估报告及评估说明",
  "enabled": true,
  "source_type": "valuation_project_folder",
  "input_root": "Input/2",
  "batch_layout": "Input/2 的每个直接子文件夹是一份独立报告项目",
  "resources": {
    "report_template": "企业价值评估报告-自动生成基底模板.docx",
    "explanation_template": "企业价值评估说明-自动生成基底模板.docx",
    "prompt": "企业价值评估报告自动生成-Prompt.md",
    "input_schema": "企业价值评估输入数据格式.json",
    "method_library": "资产基础法评估方法库.json"
  },
  "outputs": [
    {
      "kind": "report",
      "filename": "1-评估报告-{被评估单位}-{评估基准日}.docx",
      "sections": [
        "评估对象和评估范围",
        "资产基础法具体评估方法介绍",
        "评估结论"
      ]
    },
    {
      "kind": "explanation",
      "filename": "2-评估说明-{被评估单位}-{评估基准日}.docx",
      "sections": [
        "评估对象与评估范围说明",
        "实物资产的分布情况及特点",
        "第三章：资产基础法评估技术说明"
      ]
    }
  ],
  "programmatic_section_fallbacks": {
    "scope": true,
    "method_sections": true,
    "conclusion": true,
    "physical_assets": true,
    "technical_sections": true,
    "description": "类型2 Word 渲染前会用 Excel JSON 和方法库补全对象报告式章节。Gemini 原始输出保存在 gemini_generated_sections，generated_sections 为最终用于 Word 的增强结果。"
  },
  "detail_tables": {
    "enabled": true,
    "source": "母公司评估明细表中的可见科目工作表",
    "preserve_all_rows": true,
    "send_to_ai": false,
    "insert_in_report_scope": true,
    "insert_in_explanation_technical": true,
    "report_scope_subjects": [
      "长期股权投资",
      "房屋建筑物",
      "土地使用权"
    ],
    "explanation_technical_subjects": [
      "长期股权投资",
      "房屋建筑物",
      "土地使用权"
    ],
    "max_rows_per_detail_table": 300,
    "formatting": "Word 中使用 Table Grid；完整明细表采用轻量渲染，避免逐格设置字体导致生成过慢。",
    "notes": [
      "日期列由 Excel 序列号转换为中文日期。",
      "金额、价值、原值、净值、面积、数量等列保留两位小数。",
      "账号、号码、编号、证号、权证等列若 Excel 单元格本身为文本则可保真；若源 Excel 以超长数字存储，Excel 本身可能已丢失精度，应将源列改为文本格式。"
    ]
  },
  "workpaper_tables": {
    "enabled": true,
    "source": "成本法评估过程、成本法计算过程、收益法评估过程、收益法/市场法/交易案例底稿中的案例表、参数表和修正系数表",
    "preserve_display_text": true,
    "send_to_ai": false,
    "insert_in_explanation_technical": true,
    "max_scan_rows": 500,
    "max_scan_columns": 40,
    "max_rows_per_table": 80,
    "max_columns_per_table": 40,
    "max_tables_per_workpaper": 12,
    "max_tables_per_subject": 10,
    "keywords": [
      "案例",
      "实例",
      "可比",
      "比较因素",
      "交易价格",
      "交易情况",
      "市场状况",
      "修正",
      "系数",
      "参数",
      "取费",
      "指数",
      "重置",
      "成新",
      "耐用年限",
      "尚可使用年限",
      "经济寿命",
      "折旧",
      "摊销",
      "租金",
      "收益",
      "资本化率",
      "折现率",
      "净现金流",
      "市盈率",
      "市净率",
      "P/B",
      "P/E",
      "比率",
      "折扣率",
      "溢价率",
      "权重",
      "财务指标",
      "非流动性折扣",
      "流动性折扣",
      "控制权溢价",
      "少数股权",
      "基本重置价",
      "层高调整",
      "土地使用年期"
    ],
    "notes": [
      "程序只提取候选小型案例表、参数表、修正系数表，不把整本底稿或大明细表发送给 Gemini。",
      "Word 插入时按科目匹配：土地底稿进入土地使用权，房屋/租金/重置价底稿进入房屋建筑物，交易案例/对比公司等底稿进入长期股权投资。",
      "单元格优先保留 Excel 显示文本，以保留百分比、日期、金额格式。"
    ]
  },
  "input_discovery": {
    "ignore_names": [
      "~$*"
    ],
    "excel_suffixes": [
      ".xls",
      ".xlsx",
      ".xlsm"
    ],
    "detail_workbook_name_contains": "评估明细表",
    "workpaper_name_keywords": [
      "工作底稿",
      "计算过程",
      "测算表",
      "收益法",
      "市场法",
      "交易案例"
    ],
    "visible_sheets_only": true
  },
  "primary_workbook_selection": {
    "never_merge_multiple_entities": true,
    "entity_source": "汇总-资产基础法!被评估单位",
    "priority": [
      "被评估单位与项目主体名称一致",
      "文件名以3-或3.1-开头",
      "文件名包含被评估单位简称"
    ],
    "on_ambiguous": "error"
  },
  "workbook_rules": {
    "summary_sheet": "汇总-资产基础法",
    "classification_sheet": "2分类汇总",
    "summary_unit": "人民币万元",
    "detail_default_unit": "人民币元",
    "unit_source": "工作表中的金额单位文字",
    "subject_name_from_sheet": "移除工作表名前导数字、点号及汇总字样",
    "header_detection": "按表头文字识别，支持多行和合并单元格",
    "item_count": "明细区序号列的最大有效整数",
    "exclude_rows": [
      "合计",
      "小计",
      "总计",
      "空白行"
    ]
  },
  "summary_categories": [
    "流动资产",
    "非流动资产",
    "资产总计",
    "流动负债",
    "非流动负债",
    "负债总计",
    "股东全部权益价值",
    "净资产（所有者权益）"
  ],
  "category_subjects": {
