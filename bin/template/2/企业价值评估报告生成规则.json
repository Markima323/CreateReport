      "递延所得税资产",
      "其他非流动资产"
    ],
    "流动负债": [
      "短期借款",
      "交易性金融负债",
      "衍生金融负债",
      "应付票据",
      "应付账款",
      "预收款项",
      "合同负债",
      "应付职工薪酬",
      "应交税费",
      "其他应付款",
      "持有待售负债",
