    "其他无形资产": "其他无形资产"
  },
  "scope_rules": {
    "report_object": "{被评估单位}于评估基准日的股东全部权益价值",
    "include_only_nonzero_book_categories": true,
    "include_only_nonzero_book_subjects": true,
    "noncurrent_rows_include_only_nonzero_book_value": true,
    "zero_book_positive_assessed_omit_from_main_assets": true,
    "zero_book_technical_intangibles_to_off_balance": true,
    "no_off_balance_text": "本次评估企业无申报的表外资产。",
    "reference_other_reports_default": "本资产评估报告的评估结论无引用其他机构出具的报告的结论。"
  },
  "description_rules": {
    "money_unit": "万元",
    "money_decimals": 2,
    "normal_subject": "账面价值{账面价值万元}万元",
    "impairment_zero": "未计提{准备名称}",
    "impairment_nonzero": "计提{准备名称}{准备金额万元}万元",
    "count_source": "最大有效序号",
    "content_columns": [
      "名称",
      "名称及规格型号",
      "设备名称",
      "业务内容"
    ],
    "few_types": "完整列示",
    "many_types": "按出现次数和金额合计排序后选取主要类型",
    "age_summary": "选择金额占比最高的账龄区间"
  },
  "physical_asset_subjects": [
    "存货",
    "房屋建筑物",
    "构筑物及其他辅助设施",
    "机器设备",
    "车辆",
    "电子设备",
    "在建工程",
    "土地使用权"
  ],
  "method_rules": {
    "order_source": "2分类汇总中的科目顺序",
    "include_when": "账面价值不为0或评估价值不为0",
    "completed_report_priority": true,
    "fallback_library": "资产基础法评估方法库.json",
    "require_workpaper_method_for": [
      "房屋建筑物",
      "构筑物及其他辅助设施",
      "投资性房地产",
      "土地使用权",
      "技术类无形资产"
    ],
    "on_method_unknown": "warning_and_leave_blank"
  },
  "conclusion_rules": {
    "source": "汇总-资产基础法",
    "never_overwrite_source_numbers_with_ai": true,
    "checks": [
      "评估价值-账面价值=增减值",
      "账面价值非0时增减值/账面价值=增值率",
      "资产总计-负债总计=股东全部权益价值"
    ],
    "rate_tolerance": 0.0001,
    "amount_tolerance_wanyuan": 0.01,
    "final_method_source": "项目明确资料",
    "on_final_method_unknown": "do_not_choose"
  },
  "equipment_rules": {
    "enabled_as_optional_stage": true,
    "sample_ratio": 0.1,
    "price_priority": [
      "名称和规格型号相似度",
      "未折扣价格接近账面原值乘以1.13",
      "启用日期与价格的合理关系"
    ],
    "electronic_depreciates_faster": true,
    "shared_source_for_similar_items": true,
    "market_source_action": {
      "取价依据": "URL",
      "购置单价（含税价）": "原始报价"
    },
    "no_market_source_action": {
      "取价依据": "价格指数",
      "categories": [
        "通用设备",
        "专用设备",
        "电子设备",
        "家具"
      ],
      "period": "评估基准日前最近一期"
    },
    "started_within_six_months": {
      "取价依据": "账面价值"
    },
    "life_year_source": "统一年限.xlsx",
    "default_life_years": {
      "电子设备": 8,
      "通用机器设备": 12
    }
  },
  "ai": {
    "provider": "Google Gemini",
    "model": "gemini-3.5-flash",
    "thinking_level": "medium",
    "store_interactions": false,
    "structured_json_only": true,
    "serial_requests": true,
    "allow_web_search_for_project_facts": false
  },
  "validation": {
    "required_project_fields": [
      "被评估单位",
      "评估基准日"
    ],
    "required_sheets": [
      "汇总-资产基础法",
      "2分类汇总"
    ],
    "forbid_example_facts": true,
    "forbid_hidden_sheet_data": true,
    "forbid_parent_subsidiary_merge": true,
    "unresolved_placeholder_is_error": true
  }
