  "subject_aliases": {
    "预付账款": "预付款项",
    "银行存款": "货币资金",
    "现金": "货币资金",
    "其他货币资金": "货币资金",
    "长期待摊": "长期待摊费用",
    "其他流资": "其他流动资产",
    "固定资产汇总": "固定资产",
    "无形资产汇总": "无形资产",
    "在建工程汇总": "在建工程",
    "在建工程土建": "在建工程",
    "在建工程设备": "在建工程",
    "机器设备": "机器设备",
    "办公电子设备": "电子设备",
    "电子设备": "电子设备",
    "房屋建筑物": "房屋建筑物",
